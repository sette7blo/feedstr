# Feedstr local configuration
#
# Generate this token in Idenstr > API tokens. Name it "feedstr" and grant:
# profile:read, following:read, relays:read, sign:kind:1, sign:kind:6, sign:kind:7
FEEDSTR_IDENSTR_URL=http://host.docker.internal:3000
FEEDSTR_IDENSTR_TOKEN=idstr_paste_token_here

# Idenstr's private relay (the embedded Strfry vault). Read from it directly in
# addition to public read relays. Use the LAN or Tailscale address of the host
# running Idenstr, reachable from the browser. Editable + testable in the UI
# (Idenstr connection > Private relay), which saves back here.
FEEDSTR_PRIVATE_RELAY_URL=ws://192.168.2.199:7777

FEEDSTR_HOST_BIND=127.0.0.1
FEEDSTR_HOST_PORT=3002
